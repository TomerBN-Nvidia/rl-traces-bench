# reproducer/configs/baseline.env
# Baseline A/B cell: prefix caching on, chunked prefill off. No MTP.
# Sourced by serve/serve_super_bf16_hsg.sh on HSG — not used locally.
MODEL="<SUPER_BF16_CKPT_PATH>"          # fill from design §10 Q4 on first real run
TP=4
EXTRA_SERVE_ARGS=(--enable-prefix-caching --no-enable-chunked-prefill)
# CUDA graphs ON (never --enforce-eager). ignore_eos handled by run_batch client args.
