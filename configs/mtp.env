# reproducer/configs/mtp.env — same as baseline + MTP speculative decoding
# Sourced by serve/serve_super_bf16_hsg.sh on HSG — not used locally.
# NOTE: "method" is a placeholder ("...") like <SUPER_BF16_CKPT_PATH> — fill in
# the real MTP method name (ties to dynamic-draft-length-tau2) before the first
# real HSG run.
# EXTRA_SERVE_ARGS is a bash ARRAY (not a string) so the embedded JSON stays a
# single argv token when serve_super_bf16_hsg.sh expands it as
# "${EXTRA_SERVE_ARGS[@]}" — do not convert this back to a plain string.
MODEL="<SUPER_BF16_CKPT_PATH>"
TP=4
EXTRA_SERVE_ARGS=(--enable-prefix-caching --speculative-config '{"method":"...","num_speculative_tokens":5}')
